    #include<stdio.h>
    #include<stdlib.h>
    #include<string.h>
    #include<dirent.h>
    #include<ctype.h>
    #include<time.h>
    #include<unistd.h>
    #include<fcntl.h>
    #include<inttypes.h>
    int main()
    {
        static long user,nice,sys,idle;
        long new_user,new_nice,new_sys,new_idle;
        float cpu,mem;
        float load[3];
        int flags=fcntl(STDIN_FILENO,F_GETFL,0);
        fcntl(STDIN_FILENO,F_SETFL,flags|O_NONBLOCK);
        while(1){
            system("clear");
            fflush(stdout);
            FILE *fp_stat=fopen("/proc/stat","r");
            fscanf(fp_stat,"cpu %ld %ld %ld %ld",&new_user,&new_nice,&new_sys,&new_idle);
            fclose(fp_stat);
            long total_time=(new_user-user)+(new_nice-nice)+(new_sys-sys)+(new_idle-idle);
            long work_time=(new_user-user)+(new_nice-nice)+(new_sys-sys);
            cpu=(float)work_time/total_time*100;
            user=new_user;
            nice=new_nice;
            sys=new_sys;
            idle=new_idle;
            unsigned long long mem_total=0,mem_available=0;
            FILE *fp_meminfo=fopen("/proc/meminfo","r");
            char line[512];
            while (fgets(line,sizeof(line),fp_meminfo))
            {
                sscanf(line,"MemTotal: %llu kB",&mem_total);
                sscanf(line,"MemAvailable: %llu kB",&mem_available);
            };
            fclose(fp_meminfo);
            mem=100.0*(mem_total-mem_available)/mem_total;
            FILE *fp_loadavg=fopen("/proc/loadavg","r");
            fscanf(fp_loadavg,"%f %f %f",&load[0],&load[1],&load[2]);
            fclose(fp_loadavg);
            time_t now=time(NULL);
            printf("===== 简易的系统监控器 =====\n");
            printf("当前时间: %s",ctime(&now));
            printf("CPU 使用率: %.1f%%\n",cpu);
            printf("内存使用率: %.1f%%\n",mem);
            printf("系统负载: %.2f %.2f %.2f\n",load[0],load[1],load[2]);
            printf("---------------------------------\n");
            printf("进程ID\t进程名称\n");
            printf("---------------------------------\n");
            DIR *dir=opendir("/proc");
            if(dir)
            {
                struct dirent *entry;
                while((entry=readdir(dir))!=NULL)
                {
                    const char *name=entry->d_name;
                    int ispid=1;
                    while(*name)
                    {if(!isdigit(*name))
                    {
                        ispid=0;
                        break;
                    }
                    name++;
                    }
                    if(ispid)
                    {
                        char path[512];
                        snprintf(path,sizeof(path),"/proc/%s/status",entry->d_name);
                        FILE *fp=fopen(path,"r");
                        if(fp)
                        {
                            char proc_name[512]={0};
                            char line_proc[512];
                            while(fgets(line_proc,sizeof(line_proc),fp))
                            {
                                if(strncmp(line_proc,"Name:",5)==0)
                                {
                                    sscanf(line_proc+6,"%s",proc_name);
                                    break;
                                }
                            }
                            fclose(fp);
                            printf("%s\t%s\n",entry->d_name,proc_name);

                        }
                    }
                }
                closedir(dir);
            }
            char ch;
            if(read(STDIN_FILENO,&ch,1)>0){
                if(ch=='q')
                {
                    fcntl(STDIN_FILENO,F_SETFL,flags);
                    break;
            }
                
            }
            else if (ch=='r')
            {
                continue;
            }
            sleep(1);
        }

        return 0;
    }
